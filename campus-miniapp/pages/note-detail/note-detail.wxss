/* 作者栏 */
.author-bar {
  position: relative;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 190rpx 20rpx 24rpx;
  margin-bottom: 20rpx;
  min-height: 90rpx;
}

.author-info {
  flex: 1;
  min-width: 0;
}
.author-name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.author-campus {
  font-size: 22rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 2rpx;
}

.author-btns {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.follow-pill {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 26rpx;
  background: #ff6b6b;
  color: #fff;
  flex-shrink: 0;
}

.share-pill {
  font-size: 24rpx;
  background: none;
  border: none;
  padding: 10rpx 14rpx;
  margin: 0;
  line-height: 1;
  height: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  flex-shrink: 0;
}
.share-pill::after { border: none; }

/* 标题和正文 */
.note-title { font-size: 38rpx; font-weight: 700; margin-bottom: 20rpx; line-height: 1.4; }
.note-content { font-size: 30rpx; line-height: 1.8; color: #444; margin-bottom: 24rpx; }

/* 图片 */
.image-swiper { width: 100%; height: 560rpx; border-radius: 16rpx; overflow: hidden; margin-bottom: 20rpx; }
.note-image { width: 100%; }

/* 标签 */
.tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.tag { color: #5b8def; font-size: 24rpx; background: rgba(91,141,239,0.08); padding: 6rpx 16rpx; border-radius: 20rpx; }

/* 位置+时间 */
.meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  flex-wrap: wrap;
}
.publish-time { color: #bbb; }
.view-count { color: #bbb; margin-left: auto; }

/* 操作栏（赞藏评） */
.action-bar {
  display: flex;
  justify-content: flex-start;
  gap: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 30rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-emoji { font-size: 36rpx; }
.action-count { font-size: 28rpx; font-weight: 600; color: #333; }
.action-item.liked .action-count { color: #ff6b6b; }
.action-item.collected .action-count { color: #ffa940; }

/* 评论列表 */
.comment-section { margin-bottom: 20rpx; }
.comment-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.comment-item { display: flex; gap: 16rpx; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.comment-body { flex: 1; }
.comment-name { font-weight: 500; margin-right: 12rpx; }
.comment-time { font-size: 22rpx; }
.comment-content { display: block; margin-top: 8rpx; font-size: 28rpx; }
.replies { background: #f8f8f8; border-radius: 12rpx; padding: 16rpx; margin-top: 12rpx; }
.reply-item { padding: 8rpx 0; font-size: 26rpx; }
.reply-name { color: #ff6b6b; margin-right: 8rpx; }
.empty-comment { text-align: center; padding: 60rpx 0; }

/* 底部输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  padding: 12rpx 20rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f6f6f6;
  border-radius: 34rpx;
  padding-right: 8rpx;
}

.msg-input {
  flex: 1;
  height: 68rpx;
  background: transparent;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.send-btn {
  background: #ff6b6b;
  color: #fff;
  border-radius: 26rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  flex-shrink: 0;
}

.input-like, .input-collect {
  font-size: 26rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.input-like.liked { color: #ff6b6b; }
.input-collect.collected { color: #ffa940; }

.empty-tip { text-align: center; padding: 80rpx 0; }
