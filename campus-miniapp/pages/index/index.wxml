<wxs src="../../utils/time.wxs" module="time" />

<!-- 顶部栏：学校切换 + 搜索 -->
<view class="top-bar">
  <view class="school-switcher" bindtap="switchSchool">
    <text class="school-icon">🏫</text>
    <text class="school-name">{{currentSchool || '河北外国语学院'}}</text>
    <text class="school-arrow">▾</text>
  </view>
  <view class="sort-toggle" bindtap="toggleSort">
    <text>{{sortLabel === '🔥最热' ? '🔥' : '📋'}} {{sortLabel}}</text>
  </view>
  <view class="search-bar-inline" bindtap="goSearch">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索...</text>
  </view>
</view>

<!-- 首页信息流 -->
<view class="container">
  <!-- 双列瀑布流 -->
  <view wx:if="{{!loading && notes.length > 0}}" class="waterfall">
    <view class="waterfall-col">
      <view wx:for="{{leftNotes}}" wx:key="id" class="note-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-img-wrap">
          <image wx:if="{{item.images.length > 0}}" class="card-img img-fade-in" src="{{item.images[0]}}" mode="widthFix" lazy-load binderror="onImgError" />
          <view wx:else class="card-img-placeholder">
            <text class="placeholder-icon">📝</text>
          </view>
          <view wx:if="{{item.images.length > 1}}" class="img-count-badge">{{item.images.length}}图</view>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <image class="avatar-xs" src="{{item.user.avatarUrl || '/images/default-avatar.png'}}" />
            <text class="card-author text-ellipsis">{{item.user.nickname}}</text>
            <text wx:if="{{currentSchool && item.campus && item.campus !== myCampus}}" class="card-campus">{{item.campus}}</text>
            <text class="card-time">{{time.ago(item.createTime)}}</text>
            <text class="card-likes">❤ {{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="waterfall-col">
      <view wx:for="{{rightNotes}}" wx:key="id" class="note-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-img-wrap">
          <image wx:if="{{item.images.length > 0}}" class="card-img img-fade-in" src="{{item.images[0]}}" mode="widthFix" lazy-load binderror="onImgError" />
          <view wx:else class="card-img-placeholder">
            <text class="placeholder-icon">📝</text>
          </view>
          <view wx:if="{{item.images.length > 1}}" class="img-count-badge">{{item.images.length}}图</view>
        </view>
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <view class="card-footer">
            <image class="avatar-xs" src="{{item.user.avatarUrl || '/images/default-avatar.png'}}" />
            <text class="card-author text-ellipsis">{{item.user.nickname}}</text>
            <text wx:if="{{currentSchool && item.campus && item.campus !== myCampus}}" class="card-campus">{{item.campus}}</text>
            <text class="card-time">{{time.ago(item.createTime)}}</text>
            <text class="card-likes">❤ {{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载/空状态 -->
  <view wx:if="{{loading}}" class="empty-tip">
    <text class="text-muted">加载中...</text>
  </view>
  <view wx:elif="{{notes.length === 0}}" class="empty-tip">
    <text class="text-muted">还没有笔记，快来发布第一条吧</text>
  </view>
</view>
