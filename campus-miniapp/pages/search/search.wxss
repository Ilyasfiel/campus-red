.search-bar {
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.search-btn {
  background: #ff6b6b;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0 32rpx;
  height: 76rpx;
  line-height: 76rpx;
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  color: #ff6b6b;
  font-size: 26rpx;
  background: rgba(255,107,107,0.1);
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
}

.hot-tags {
  padding-top: 20rpx;
}

.search-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.search-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.search-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.search-title {
  font-size: 30rpx;
  font-weight: 500;
}

.search-content {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
}
