# Campus Red 环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/campus_red?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT密钥（至少256位，生产环境务必更换为随机字符串）
JWT_SECRET=change-me-to-a-random-256-bit-secret

# 文件上传路径
UPLOAD_PATH=./uploads

# 微信小程序AppID（如需微信登录）
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret
